---
import Layout from "../layouts/Layout.astro"
---
<div id="overlay" class="fixed inset-0 z-40 hidden bg-black/50 backdrop-blur-sm transition-opacity"></div>

<nav class="relative z-50 w-full bg-white">
    <div class="flex justify-between items-center py-4 px-6 max-w-7xl mx-auto">
        <div>
            <img src="/images/logo-dark.svg" alt="Logo" width="160" class="md:w-50">
        </div>

        <div id="menu-button" class="md:hidden cursor-pointer">
            <img src="/images/menu.png" alt="Menu" width="26">
        </div>
        
        <div id="menu-list" class="text-[17px] hidden md:flex gap-6 lg:gap-9 absolute md:relative top-20 md:top-0 left-6 right-6 md:left-0 md:right-0 bg-white md:bg-transparent flex-col md:flex-row p-6 md:p-0 shadow-xl md:shadow-none rounded-lg md:rounded-none text-center md:text-left font-medium text-gray-700">
            <a href="#" class="hover:text-black transition-colors">Home</a>
            <a href="#" class="hover:text-black transition-colors">About</a>
            <a href="#" class="hover:text-black transition-colors">Contact</a>
            <a href="#" class="hover:text-black transition-colors">Blog</a>
            <a href="#" class="hover:text-black transition-colors">Career</a>
        </div>
        
        <span class="hidden md:block text-white bg-linear-to-bl from-[hsl(136,64%,51%)] to-[hsl(192,69%,51%)] py-3 px-8 rounded-full font-medium whitespace-nowrap cursor-pointer hover:opacity-90 transition-opacity">
            Request Invite
        </span>
    </div>
</nav>

<style>
    span{
        font-family: "Montserrat", sans-serif;
        font-weight: 500;
    }
    #menu-list {
        font-family: "Montserrat", sans-serif;
        font-weight: 500;
        color: rgb(61, 61, 61);
    }

    @media (max-width: 940px){
        span{
            display: none;
        }

    }
</style>

<script>
    const BUTTON_MENU = document.getElementById('menu-button');
    const MENU_LIST = document.getElementById('menu-list');
    const OVERLAY = document.getElementById('overlay');

    const toggleMenu = () => {
        // Alternar visibilidad del menú
        MENU_LIST?.classList.toggle('hidden');
        MENU_LIST?.classList.toggle('flex');
        
        // Alternar visibilidad del fondo oscuro
        OVERLAY?.classList.toggle('hidden');
    };

    // Abrir menú al hacer clic en el botón
    BUTTON_MENU?.addEventListener('click', toggleMenu);

    // Cerrar menú al hacer clic en el fondo oscuro
    OVERLAY?.addEventListener('click', toggleMenu);
</script>