---
import Layout from "../layouts/Layout.astro"
---
<div id="overlay" class="fixed inset-0 z-40 hidden bg-black/50 backdrop-blur-sm transition-opacity"></div>

<nav class="relative z-50 w-full">
    <div class="flex justify-between items-center py-4 px-6 bg-white">
        <div>
            <img src="/public/images/logo-dark.svg" alt="" width="200">
        </div>
        <div id="menu-button" class="md:hidden cursor-pointer">
            <img src="/public/images/menu.png" alt="" width="26">
        </div>
        
        <div id="menu-list" class="text-[17px] hidden md:flex gap-9 absolute md:relative top-16 md:top-0 left-0 w-full md:w-auto bg-white flex-col md:flex-row p-4 md:p-0 shadow-md md:shadow-none transition-all">
            <a href="" class="">Home</a>
            <a href="">About</a>
            <a href="">Contact</a>
            <a href="">Blog</a>
            <a href="">Career</a>
        </div>
        
        <span class="text-white bg-linear-to-bl from-[hsl(136,64%,51%)] to-[hsl(192,69%,51%)] py-3 px-9 rounded-[40px] ">Request Invite</span>

    </div>
</nav>

<style>
    span{
        font-family: "Montserrat", sans-serif;
        font-weight: 500;
    }
    #menu-list {
        font-family: "Montserrat", sans-serif;
        font-weight: 500;
        color: rgb(61, 61, 61);
    }

    @media (max-width: 940px){
        span{
            display: none;
        }

    }
</style>

<script>
    const BUTTON_MENU = document.getElementById('menu-button');
    const MENU_LIST = document.getElementById('menu-list');
    const OVERLAY = document.getElementById('overlay');

    const toggleMenu = () => {
        // Alternar visibilidad del menú
        MENU_LIST?.classList.toggle('hidden');
        MENU_LIST?.classList.toggle('flex');
        
        // Alternar visibilidad del fondo oscuro
        OVERLAY?.classList.toggle('hidden');
    };

    // Abrir menú al hacer clic en el botón
    BUTTON_MENU?.addEventListener('click', toggleMenu);

    // Cerrar menú al hacer clic en el fondo oscuro
    OVERLAY?.addEventListener('click', toggleMenu);
</script>